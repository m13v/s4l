{
  "_comment": "Add this `web_chat` block to each project entry in config.json that should host the FounderChatPanel widget. Per-project values override the defaults shown here.",

  "_example_full_project_entry_with_web_chat": {
    "name": "Mediar",
    "website": "https://mediar.ai",
    "web_chat": {
      "enabled": true,
      "notify_email": "matt@mediar.ai",
      "founder_name": "matt",
      "greeting": "hey, i'm matt, the founder. drop a question or feedback and i'll get back to you.",
      "reply_eta": "usually replies within a couple hours",
      "from_email": "Matt from Mediar <matt@mediar.ai>"
    }
  },

